{
  "name": "nangok-member",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "verify:phase1": "node scripts/verify-phase-1.mjs",
    "members:validate": "tsx scripts/members/validate-members.ts",
    "members:prepare": "tsx scripts/members/prepare-members.ts",
    "members:import": "tsx scripts/members/import-members.ts",
    "typecheck:members": "tsc -p tsconfig.members.json",
    "test:phase2": "tsx --test scripts/members/__tests__/phase2.test.ts",
    "verify:phase2": "npm run typecheck:members && npm run test:phase2 && node scripts/verify-phase-2.mjs",
    "test:phase3": "tsx --test src/lib/__tests__/phase3.test.ts",
    "verify:phase3": "npm run build && npm run test:phase3 && node scripts/verify-phase-3.mjs",
    "test:phase4": "tsx --test src/lib/__tests__/phase4.test.ts",
    "verify:phase4": "npm run build && npm run test:phase3 && npm run test:phase4",
    "verify:phase5": "npm run build && npm run verify:phase1 && npm run verify:phase2 && npm run verify:phase3 && npm run verify:phase4 && node scripts/verify-phase-5.mjs",
    "verify:deploy": "npm run build && node scripts/verify-phase-5.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
